{
  "name": "spec-graph",
  "displayName": "Spec Graph",
  "description": "Feature Dependency Graph 시각화 - 스펙 트리뷰 및 Cytoscape.js 기반 그래프 렌더링",
  "version": "0.1.52",
  "publisher": "flow-team",
  "repository": {
    "type": "git",
    "url": "https://github.com/flow-team/flow"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:docs/specs/*.json",
    "workspaceContains:**/docs/specs/*.json",
    "workspaceContains:.flow/config.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "specGraph",
          "title": "Spec Graph",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "specGraph": [
        {
          "id": "specTree",
          "name": "스펙 트리",
          "icon": "resources/icon.svg"
        },
        {
          "id": "specDetail",
          "type": "webview",
          "name": "스펙 상세",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "specGraph.openGraph",
        "title": "Spec Graph: 그래프 열기",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "specGraph.openGraphPreview",
        "title": "Spec Graph: 웹 프리뷰 열기",
        "icon": "$(browser)"
      },
      {
        "command": "specGraph.refresh",
        "title": "Spec Graph: 새로고침",
        "icon": "$(refresh)"
      },
      {
        "command": "specGraph.focusNode",
        "title": "Spec Graph: 노드 포커스"
      },
      {
        "command": "specGraph.openSpec",
        "title": "Spec Graph: 스펙 파일 열기",
        "icon": "$(go-to-file)"
      },
      {
        "command": "specGraph.filterByStatus",
        "title": "Spec Graph: 상태별 필터",
        "icon": "$(filter)"
      },
      {
        "command": "specGraph.filterByTag",
        "title": "Spec Graph: 태그별 필터",
        "icon": "$(tag)"
      },
      {
        "command": "specGraph.debugInfo",
        "title": "Spec Graph: 디버그 정보",
        "icon": "$(info)"
      },
      {
        "command": "specGraph.openSpecView",
        "title": "Spec Graph: 스펙 문서 보기",
        "icon": "$(open-preview)"
      },
      {
        "command": "specGraph.openSpecViewFocused",
        "title": "Spec Graph: 선택 스펙 문서 보기",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "specGraph.openGraph",
          "when": "view == specTree",
          "group": "navigation"
        },
        {
          "command": "specGraph.refresh",
          "when": "view == specTree",
          "group": "navigation"
        },
        {
          "command": "specGraph.openGraphPreview",
          "when": "view == specTree",
          "group": "navigation"
        },
        {
          "command": "specGraph.openSpecView",
          "when": "view == specTree",
          "group": "navigation"
        },
        {
          "command": "specGraph.filterByStatus",
          "when": "view == specTree",
          "group": "navigation"
        },
        {
          "command": "specGraph.debugInfo",
          "when": "view == specTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "specGraph.openSpec",
          "when": "view == specTree",
          "group": "inline"
        },
        {
          "command": "specGraph.focusNode",
          "when": "view == specTree"
        },
        {
          "command": "specGraph.openSpecViewFocused",
          "when": "view == specTree"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap && node -e \"require('fs').copyFileSync('node_modules/cytoscape/dist/cytoscape.min.js', 'dist/cytoscape.min.js')\"",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "build": "npm run compile",
    "package": "vsce package --no-dependencies --allow-missing-repository",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "cytoscape": "^3.28.0"
  }
}
