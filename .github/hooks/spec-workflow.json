{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "pwsh -NoProfile -File scripts/hooks/session-start.ps1",
        "timeout": 30
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "pwsh -NoProfile -File scripts/hooks/prompt-submit.ps1",
        "timeout": 15
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "pwsh -NoProfile -File scripts/hooks/on-stop.ps1",
        "timeout": 30
      }
    ]
  }
}
